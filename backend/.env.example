# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/f1_analytics
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_URL=redis://localhost:6379/0

# FastF1
FASTF1_CACHE_DIR=./data/fastf1_cache
FASTF1_CACHE_ENABLED=true

# Data Storage
DATA_DIR=./data
PARQUET_DIR=./data/telemetry
MODEL_DIR=./models

# ML Config
ML_TRAINING_ENABLED=true
ML_LOOKBACK_RACES=10
ML_RETRAIN_SCHEDULE="0 2 * * 1"  # Every Monday at 2 AM

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Monitoring
PROMETHEUS_ENABLED=true
LOG_LEVEL=INFO

# Feature Flags
ENABLE_LIVE_MODE=false
ENABLE_WEBSOCKET=true
